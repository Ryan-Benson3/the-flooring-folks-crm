# ─────────────────────────────────────────────────────────────
# The Flooring Folks CRM — environment template
# Copy to .env and fill in real values. NEVER commit real secrets.
# (.env* is gitignored; this template intentionally has empty values.)
# ─────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────
# Public site URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────
# Project URL + browser-safe anon key (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Used for privileged operations (migrations, support access) behind the server.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ──────────────────────────────────────────────────
# Secret + webhook signing secret — SERVER ONLY.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Publishable key — safe to expose in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Receipt OCR / AI ───────────────────────────────────────
# Vendor-agnostic placeholders. Wire whichever provider lands in Phase 7/18.
# OCR/AI may only ever produce reviewable drafts — never finalize money.
OCR_API_KEY=
AI_API_KEY=
